import express from "express";
import dotenv from "dotenv";
import { GoogleGenerativeAI } from "@google/generative-ai";

dotenv.config();

const app = express();
app.use(express.json());

const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY || "");

app.post("/api/generate-strategy", async (req, res) => {
  try {
    const { whoAreYou, whoAreYouTalkingTo, whatToCommunicate, platform } = req.body;
    
    if (!whatToCommunicate) {
      return res.status(400).json({ error: "El campo qué quieres comunicar es obligatorio." });
    }

    const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });

    const prompt = `Actúa como un estratega creativo experto. 
    Genera una respuesta en formato JSON puro (sin formato markdown) que contenga un array llamado "strategies" con 3 objetos. 
    Cada objeto debe tener: "hook", "angulo", "enfoque", "formato", "emocion", "percentage".
    Contexto: ${whoAreYou} hablando a ${whoAreYouTalkingTo} sobre "${whatToCommunicate}" para ${platform}.`;

    const result = await model.generateContent(prompt);
    const responseText = result.response.text();
    const cleaned = responseText.replace(/```json/g, "").replace(/```/g, "").trim();
    
    res.json(JSON.parse(cleaned));
  } catch (error) {
    console.error("Error en el motor:", error);
    res.status(500).json({ error: "Error interno del servidor" });
  }
});

export default app;
